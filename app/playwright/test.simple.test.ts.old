import { test, expect } from '@playwright/test';
import fs from 'fs';
import path from 'path';

// Generate timestamped folder name
const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
const resultsDir = path.resolve('./playwright-results');
const testRunDir = path.join(resultsDir, `test-${timestamp}`);

// Ensure the folders exist before tests run
test.beforeAll(async () => {
  if (!fs.existsSync(resultsDir)) {
    fs.mkdirSync(resultsDir, { recursive: true });
  }
  if (!fs.existsSync(testRunDir)) {
    fs.mkdirSync(testRunDir, { recursive: true });
  }
});

test.afterEach(async ({ page }, testInfo) => {
  // Wait for video to be saved and copy it to our custom directory
  await page.context().close();
  
  // Get video path from test info
  const video = testInfo.attachments.find(a => a.contentType === 'video/webm');
  if (video && video.path && fs.existsSync(video.path)) {
    const destPath = path.join(testRunDir, 'test-video.webm');
    fs.copyFileSync(video.path, destPath);
    console.log(`Video saved to: ${destPath}`);
  } else {
    // Fallback: look in test-results directory
    const testResultsDir = path.resolve('./test-results');
    if (fs.existsSync(testResultsDir)) {
      const findVideos = (dir: string): string[] => {
        const files: string[] = [];
        const items = fs.readdirSync(dir, { withFileTypes: true });
        for (const item of items) {
          const fullPath = path.join(dir, item.name);
          if (item.isDirectory()) {
            files.push(...findVideos(fullPath));
          } else if (item.name.endsWith('.webm')) {
            files.push(fullPath);
          }
        }
        return files;
      };
      
      const videoFiles = findVideos(testResultsDir);
      if (videoFiles.length > 0) {
        const latestVideo = videoFiles[videoFiles.length - 1];
        const destPath = path.join(testRunDir, 'test-video.webm');
        fs.copyFileSync(latestVideo, destPath);
        console.log(`Video saved to: ${destPath}`);
      }
    }
  }
});

test.use({
  viewport: {
    width: 1440,
    height: 900
  },
  video: {
    mode: 'on',
    size: { width: 1440, height: 900 }
  }
});

test.describe.configure({ timeout: 60000 });

